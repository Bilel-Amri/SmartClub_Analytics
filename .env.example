# Django
DJANGO_SECRET_KEY=change-me-in-production-use-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database (Docker Compose)
USE_POSTGRES=1
POSTGRES_DB=smartclub
POSTGRES_USER=smartclub
POSTGRES_PASSWORD=smartclub_dev
POSTGRES_HOST=db
POSTGRES_PORT=5432

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8080

# Optional REST permissions override
# DRF_DEFAULT_PERMISSION_CLASS=rest_framework.permissions.IsAuthenticated

# ML artifacts path (override if needed)
# ML_ARTIFACTS_DIR=/ml/artifacts

# Dataset paths (used by management commands)
SOCCERMON_PATH=C:\path\to\smartclub_analytics\subjective
FOODDATA_PATH=C:\path\to\FoodData_Central_foundation_food_csv_2025-12-18

# LLM Provider (choose one)
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.1-8b-instant

# Optional fallback (if provider fails / rate-limited)
# FALLBACK_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# FALLBACK_MODEL=qwen2.5:3b

# OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# LLM_MODEL=gpt-4o-mini

# OpenRouter
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# LLM_MODEL=openai/gpt-4o-mini

# Ollama (local)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=qwen2.5:3b
